%global debug_package %{nil}
%global _debugsource_packages 0

Name:           @PKG_NAME@
Version:        @KREL_VERSION@
Release:        1%{?dist}
Summary:        Boot files for the gaokun3 kernel
License:        GPL-2.0-only
BuildArch:      aarch64
Source0:        @SOURCE_NAME@

%description
Boot image, dtb, config, and System.map for the gaokun3 kernel @KREL@.

%prep
%setup -q -c -T
tar -xzf %{SOURCE0}

%build

%install
mkdir -p %{buildroot}
cp -a boot %{buildroot}/

%files
/boot/vmlinuz-@KREL@
/boot/System.map-@KREL@
/boot/config-@KREL@
/boot/dtb-@KREL@/qcom/@DTB_FILE@

%changelog
* Sat Mar 28 2026 cool <bilibili@att.net> - @KREL_VERSION@-1
- Build gaokun3 kernel boot RPM
