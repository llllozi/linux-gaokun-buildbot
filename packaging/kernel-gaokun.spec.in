%global debug_package %{nil}
%global _debugsource_packages 0

Name:           kernel-gaokun
Version:        @KREL_VERSION@
Release:        1%{?dist}
Summary:        Boot files for the gaokun3 kernel
License:        GPL-2.0-only
BuildArch:      aarch64
Source0:        kernel-gaokun.tar.gz

%description
Boot image, dtb, config, and System.map for the gaokun3 kernel @KREL@.

%prep
%setup -q -c -T
tar -xzf %{SOURCE0}

%build

%install
mkdir -p %{buildroot}
cp -a boot %{buildroot}/

%files
/boot/vmlinuz-@KREL@
/boot/System.map-@KREL@
/boot/config-@KREL@
/boot/dtb-@KREL@/qcom/sc8280xp-huawei-gaokun3.dtb

%changelog
* Fri Mar 27 2026 cool <bilibili@att.net> - @KREL_VERSION@-1
- Build gaokun kernel boot RPM
