%global debug_package %{nil}
%global _debugsource_packages 0

Name:           linux-firmware-gaokun
Version:        1
Release:        1%{?dist}
Summary:        Firmware bundle for gaokun3
License:        Redistributable, no modification permitted
BuildArch:      noarch
Source0:        linux-firmware-gaokun.tar.gz

%description
Firmware bundle for Huawei MateBook E Go 2023 image builds.

%prep
%setup -q -c -T
tar -xzf %{SOURCE0}

%build

%install
mkdir -p %{buildroot}
cp -a usr %{buildroot}/

%files
/usr/lib/firmware/ath11k/*
/usr/lib/firmware/qca/*
/usr/lib/firmware/qcom/*

%changelog
* Fri Mar 27 2026 cool <bilibili@att.net> - 1-1
- Build gaokun firmware RPM
