#!/usr/bin/env bash
set -euo pipefail

SRC_MONITORS="/home/user/.config/monitors.xml"
SENTINEL="/var/lib/.gaokun-monitors-synced"

pick_gdm_dir() {
  local candidate

  for candidate in \
    /var/lib/gdm3/.config \
    /var/lib/gdm/.config \
    /var/lib/gdm/seat0/config; do
    if [[ -d "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

[[ -f "$SRC_MONITORS" ]] || exit 0
[[ ! -e "$SENTINEL" ]] || exit 0

for _ in $(seq 1 30); do
  if GDM_DIR="$(pick_gdm_dir)"; then
    DST_MONITORS="$GDM_DIR/monitors.xml"
    cp "$SRC_MONITORS" "$DST_MONITORS"
    chown --reference="$GDM_DIR" "$DST_MONITORS"
    touch "$SENTINEL"
    systemctl disable gdm-monitor-sync.service || true
    systemctl try-restart gdm.service || true
    exit 0
  fi
  sleep 1
done

exit 0
